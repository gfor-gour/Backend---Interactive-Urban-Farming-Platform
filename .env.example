# ===========================
# DATABASE CONFIGURATION
# ===========================
# PostgreSQL connection string (required for Prisma)
# Format: postgresql://username:password@host:port/database
# Local: postgresql://postgres:password@localhost:5432/urban_farming_db
# Railway/Neon: provided by hosting service
DATABASE_URL=postgresql://user:password@localhost:5432/urban_farming_db

# ===========================
# SERVER CONFIGURATION
# ===========================
PORT=3000
NODE_ENV=development

# ===========================
# JWT CONFIGURATION
# ===========================
# Access token secret for short-lived tokens (15 minutes)
# Must be at least 32 characters for production
JWT_ACCESS_SECRET=your-super-secret-access-key-change-in-production

# Refresh token secret for long-lived tokens (7 days)
# Must be at least 32 characters for production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production

# ===========================
# CORS CONFIGURATION
# ===========================
# Allowed frontend origin for cross-origin requests
CORS_ORIGIN=http://localhost:3000

# ===========================
# API CONFIGURATION
# ===========================
API_VERSION=v1

# ===========================
# LOGGING (OPTIONAL)
# ===========================
# LOG_LEVEL=debug
# LOG_FILE=./logs/app.log

# ===========================
# THIRD-PARTY SERVICES (OPTIONAL)
# ===========================
# REDIS_URL=redis://localhost:6379
# MAIL_SERVICE=gmail
# MAIL_USER=your-email@gmail.com
# MAIL_PASSWORD=your-app-password

